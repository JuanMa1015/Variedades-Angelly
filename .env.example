# Root Environment Variables (canonical example for CI/CD and local overrides)

# Backend
DATABASE_URL=postgresql://user:password@host:5432/dbname
APP_ENV=development
LOGIN_RATE_LIMIT=10/minute
AUTH_BOOTSTRAP_ENABLED=true
JWT_SECRET_KEY=your-secret-key-change-this
JWT_REFRESH_EXPIRE_DAYS=30
# Example bootstrap credentials (for local testing only). Replace before production.
AUTH_SUPERADMIN_USERNAME=angelly_superadmin
AUTH_SUPERADMIN_PASSWORD=change-me-superadmin
AUTH_ADMIN_USERNAME=angelly_admin
AUTH_ADMIN_PASSWORD=change-me-admin
AUTH_SELLER_USERNAME=vendedor1
AUTH_SELLER_PASSWORD=change-me-seller
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ORIGIN_REGEX=.*\.vercel\.app$

# Frontend
VITE_API_URL=http://127.0.0.1:8000
VITE_COBRO_BANCO=<tu-banco>
VITE_COBRO_TIPO_CUENTA=<tipo-cuenta>
VITE_COBRO_NUMERO_CUENTA=<numero-cuenta>
VITE_COBRO_TITULAR_CUENTA=<titular>
VITE_COBRO_NEQUI_NUMERO=<numero-nequi>
VITE_COBRO_NEQUI_TITULAR=<titular-nequi>
