AUTH_ADMIN_PASSWORD=your-admin-password
AUTH_SELLER_USERNAME=vendedor1
AUTH_SELLER_PASSWORD=your-seller-password

# Frontend
VITE_API_URL=http://127.0.0.1:8000
VITE_COBRO_BANCO=
