APP_ENV=development
AUTH_BOOTSTRAP_ENABLED=true
JWT_SECRET_KEY=your-secret-key-change-this
AUTH_SUPERADMIN_USERNAME=angelly_superadmin
AUTH_SUPERADMIN_PASSWORD=your-superadmin-password
